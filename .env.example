# NextAuth
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Site URL (Open Graph images + auth callbacks)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Mapbox (optional — map shows fallback message without it)
NEXT_PUBLIC_MAPBOX_TOKEN=your_mapbox_public_token

# WhatsApp OTP (optional — demo mode logs OTP to server console without these)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_OTP_TEMPLATE=vasavi_login_otp

SUPERADMIN_URL=http://localhost:3001
NEXT_PUBLIC_SUPERADMIN_URL=http://localhost:3001
